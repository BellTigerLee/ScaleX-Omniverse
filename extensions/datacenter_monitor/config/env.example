# Omniverse datacenter_monitor extension — endpoint profile template.
# Copy this file to env.<name> (e.g. env.cluster-dev) and fill in real values.
# Activate with either:
#   1) ln -sfn env.<name> active
#   2) DC_PROFILE=<name> <omniverse launch command>

# k8s worker node IP reachable from your machine (where NodePort services are exposed).
CLUSTER_HOST=

# NodePort of the Kafka bootstrap Service.
KAFKA_NODEPORT=

# Topology API (canonical cluster/node/prim_name mapping). Optional — 미설정 시 Kit 이
# 씬 prim 이름 휴리스틱으로 fallback. node-state.events 소비에 정확한 매칭을 원하면 설정.
# 예: TOPOLOGY_URL=http://10.31.31.210:3001/topology
TOPOLOGY_URL=

# DEV 전용. 로컬 Flink 가 topology 에 없는 node 이름(예: work2..work8)을 보낼 때,
# 해당 이름을 topology prim 에 stable-hash 로 임의 고정 매핑해 시각화.
# 허용 값: true | 1 | yes | on  (그 외/미설정 = false).
# PoC / production profile 에는 반드시 비워두거나 false.
DEV_FAKE_NODE_MAPPING=
